{
  "manifest_version": 3,
  "name": "Mr. Transcript",
  "version": "1.0.1",
  "description": "Paste a YouTube URL, pick a language, download the full transcript in one click.",
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
